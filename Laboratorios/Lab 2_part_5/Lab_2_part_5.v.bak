module Lab_2_part_5(
    input [8:0] SW,

    output [6:0] HEX5,
    output [6:0] HEX3,
    output [6:0] HEX1,
    output [6:0] HEX0
);

wire [3:0] A;
wire [3:0] B;

assign A = SW[7:4];
assign B = SW[3:0];

reg [3:0] ones;
reg [3:0] tens;

reg [4:0] T;

always @(*)
begin

    T = A + B + SW[8];

    if(T > 9)
    begin
        ones = T - 10;
        tens = 4'b0001;
    end
    else
    begin
        ones = T[3:0];
        tens = 4'b0000;
    end

end

char_7seg HA(
    .X(A),
    .HEX(HEX5)
);

char_7seg HB(
    .X(B),
    .HEX(HEX3)
);

char_7seg HS0(
    .X(ones),
    .HEX(HEX0)
);

char_7seg HS1(
    .X(tens),
    .HEX(HEX1)
);

endmodule