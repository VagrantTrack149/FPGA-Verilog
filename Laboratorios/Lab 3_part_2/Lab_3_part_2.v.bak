module part2(Clk,D,Q);

input Clk;
input D;
output Q;

/* synthesis keep */
wire R;

/* synthesis keep */
wire S_g;

/* synthesis keep */
wire R_g;

/* synthesis keep */
wire Qa;

/* synthesis keep */
wire Qb;

wire S;

assign S = D;
assign R = ~D;

assign S_g = S & Clk;
assign R_g = R & Clk;

assign Qa = ~(R_g | Qb);
assign Qb = ~(S_g | Qa);

assign Q = Qa;

endmodule