module Lab_2_part_3(
    input [8:0] SW,
    output [9:0] LEDR
);

wire c1;
wire c2;
wire c3;
wire cout;

wire [3:0] S;

full_adder FA0(
    .a(SW[4]),
    .b(SW[0]),
    .ci(SW[8]),
    .s(S[0]),
    .co(c1)
);

full_adder FA1(
    .a(SW[5]),
    .b(SW[1]),
    .ci(c1),
    .s(S[1]),
    .co(c2)
);

full_adder FA2(
    .a(SW[6]),
    .b(SW[2]),
    .ci(c2),
    .s(S[2]),
    .co(c3)
);

full_adder FA3(
    .a(SW[7]),
    .b(SW[3]),
    .ci(c3),
    .s(S[3]),
    .co(cout)
);

assign LEDR[3:0] = S;
assign LEDR[4]   = cout;

assign LEDR[9:5] = 5'b00000;

endmodule